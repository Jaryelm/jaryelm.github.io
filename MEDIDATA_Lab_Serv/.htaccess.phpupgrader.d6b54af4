Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine on
RewriteBase /medi_data/

# Servir favicon desde icon.png existente (evita error 500)
RewriteRule ^favicon\.ico$ backend/img/icon.png [L]

RewriteCond %{SCRIPT_FILENAME} !-d
RewriteCond %{SCRIPT_FILENAME} !-f
RewriteRule ^(.*)$ $1.php
</IfModule>