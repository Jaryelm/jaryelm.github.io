# Copiar a /etc/medicasa-biometric-agent.env en el servidor físico (Ubuntu sede).
#   sudo cp medicasa-biometric-agent.env.example /etc/medicasa-biometric-agent.env
#   sudo chmod 600 /etc/medicasa-biometric-agent.env
#   sudo nano /etc/medicasa-biometric-agent.env
#
# El token MEDIDATA_AGENT_INGEST_SECRET debe ser IDÉNTICO al del servidor web
# (Apache SetEnv o biometric_ingest_secret.local.env en producción).

MEDIDATA_AGENT_REPO_ROOT=/home/medicasa/MedicasaDATAUpdate2

MEDIDATA_AGENT_INGEST_URL=https://medidata.medicasa.hn/backend/api/agent_biometric_ingest.php
MEDIDATA_AGENT_INGEST_SECRET=19843694ceb19c98f2c691ce30fcf3edc0e986a4466f7b21a7c4e73796557fb7

MEDIDATA_AGENT_SITE_CODE=Sucursal_1

MEDIDATA_RELOJ_IP=192.168.1.91
MEDIDATA_RELOJ_PORT=4370

# Opcional: timeouts UDP ZK si el pull es lento
# MEDIDATA_ZK_RECV_SEC=15
# MEDIDATA_ZK_RECDATA_MAX_SEC=90

# Solo pruebas si falla verificación SSL hacia producción:
# MEDIDATA_AGENT_VERIFY_SSL=0

# MySQL del servidor MEDIDATA actual (misma LAN/mismo host recomendado).
MEDIDATA_AGENT_DB_HOST=127.0.0.1
MEDIDATA_AGENT_DB_NAME=medic9ue_medi_data
MEDIDATA_AGENT_DB_USER=medic9ue_moisesc
MEDIDATA_AGENT_DB_PASS=Mrecords%7
