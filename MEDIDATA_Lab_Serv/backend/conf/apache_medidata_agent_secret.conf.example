# Incluir opcionalmente en C:\xampp\apache\conf\httpd.conf (final del archivo):
#
# IncludeOptional "C:/xampp/htdocs/MedicasaDATAUpdate2/backend/conf/apache_medidata_agent_secret.conf"
#
# Crear ese .conf desde la plantilla ejemplo (sin .example); el .conf real está gitignored.

<IfModule mod_env.c>
    SetEnv MEDIDATA_AGENT_INGEST_SECRET "PEGAR_HEX_IGUAL_QUE_agente_servidor_y_archivo_env"
</IfModule>
