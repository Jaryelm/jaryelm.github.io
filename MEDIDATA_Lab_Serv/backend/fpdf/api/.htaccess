# Agente biométrico — ingest POST desde servidor sede (201.190.11.6).
# En algunos hostings cPanel evita el challenge HTTP 409 / humans_* en esta ruta.
# Si no surte efecto, solicitar whitelist al proveedor para agent_biometric_ingest.php.

<IfModule mod_security2.c>
    SecRuleEngine Off
</IfModule>

<IfModule mod_security.c>
    SecFilterEngine Off
    SecFilterScanPOST Off
</IfModule>
