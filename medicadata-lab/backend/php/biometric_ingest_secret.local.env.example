# Secreto agente biométrico — SOLO laboratorio local (no subir token a Git)
# Copiar este archivo a biometric_ingest_secret.local.env y pegar tu hex real.
#
# Una línea (sin espacios alrededor del = opcionalmente con comillas):

MEDIDATA_AGENT_INGEST_SECRET=reemplazar_por_hex_64_caracteres_mismo_servidor_agente_y_credenciales

# Opcional (laboratorio): mismo site_code que envía el agente en run_once.php — para ver marcas en relojbio.php
# cuando el pull ZK por UDP falla desde esta PC (VPN/firewall).
MEDIDATA_RELJO_DB_SITE=Sucursal_1
