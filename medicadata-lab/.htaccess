Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine on
RewriteBase /medi_data/

# Servir favicon desde icon.png existente (evita error 500)
RewriteRule ^favicon\.ico$ backend/img/icon.png [L]

RewriteCond %{SCRIPT_FILENAME} !-d
RewriteCond %{SCRIPT_FILENAME} !-f
RewriteRule ^(.*)$ $1.php
</IfModule>

<IfModule mod_env.c>
    SetEnv MEDIDATA_AGENT_INGEST_SECRET "19843694ceb19c98f2c691ce30fcf3edc0e986a4466f7b21a7c4e73796557fb7"
    SetEnv MEDIDATA_RELJO_DB_SITE "Sucursal_1"
</IfModule>